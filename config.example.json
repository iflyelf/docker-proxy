{
  "_comment": "docker-proxy 配置示例。host 字段必须指向真实上游 registry，不能是本服务自己的公开域名（避免代理回环导致 403）。",
  "default_port": 5000,
  "tls_cert": "",
  "tls_key": "",
  "log_file": "docker-proxy.log",
  "registries": [
    {
      "prefix": "docker.io",
      "port": 5000,
      "mirrors": [
        {
          "host": "https://registry-1.docker.io",
          "capabilities": ["pull", "resolve"],
          "skip_verify": false
        }
      ]
    },
    {
      "prefix": "quay.io",
      "port": 5001,
      "mirrors": [
        {
          "host": "https://quay.io",
          "capabilities": ["pull", "resolve"],
          "skip_verify": false
        }
      ]
    },
    {
      "prefix": "gcr.io",
      "port": 5002,
      "mirrors": [
        {
          "host": "https://gcr.io",
          "capabilities": ["pull", "resolve"],
          "skip_verify": false
        }
      ]
    },
    {
      "prefix": "k8s.gcr.io",
      "port": 5003,
      "mirrors": [
        {
          "host": "https://k8s.gcr.io",
          "capabilities": ["pull", "resolve"],
          "skip_verify": false
        }
      ]
    },
    {
      "prefix": "registry.k8s.io",
      "port": 5004,
      "mirrors": [
        {
          "host": "https://registry.k8s.io",
          "capabilities": ["pull", "resolve"],
          "skip_verify": false
        }
      ]
    },
    {
      "prefix": "ghcr.io",
      "port": 5005,
      "mirrors": [
        {
          "host": "https://ghcr.io",
          "capabilities": ["pull", "resolve"],
          "skip_verify": false
        }
      ]
    },
    {
      "prefix": "nvcr.io",
      "port": 5008,
      "mirrors": [
        {
          "host": "https://nvcr.io",
          "capabilities": ["pull", "resolve"],
          "skip_verify": false
        }
      ]
    }
  ]
}
