{
  "default_port": 5000,
  "tls_cert": "",
  "tls_key": "",
  "log_file": "docker-proxy.log",
  "registries": [
    {
      "prefix": "docker.io",
      "port": 5000,
      "mirrors": [
        {
          "host": "https://docker.xiaonuo.live",
          "capabilities": ["pull", "resolve"],
          "skip_verify": false
        }
      ]
    },
    {
      "prefix": "quay.io",
      "port": 5001,
      "mirrors": [
        {
          "host": "https://quay.iflyelf.com",
          "capabilities": ["pull", "resolve"],
          "skip_verify": false
        }
      ]
    },
    {
      "prefix": "gcr.io",
      "port": 5002,
      "mirrors": [
        {
          "host": "https://gcr.iflyelf.com",
          "capabilities": ["pull", "resolve"],
          "skip_verify": false
        }
      ]
    },
    {
      "prefix": "k8s.gcr.io",
      "port": 5003,
      "mirrors": [
        {
          "host": "https://k8s-gcr.iflyelf.com",
          "capabilities": ["pull", "resolve"],
          "skip_verify": false
        }
      ]
    },
    {
      "prefix": "registry.k8s.io",
      "port": 5004,
      "mirrors": [
        {
          "host": "https://k8s.iflyelf.com",
          "capabilities": ["pull", "resolve"],
          "skip_verify": false
        }
      ]
    },
    {
      "prefix": "ghcr.io",
      "port": 5005,
      "mirrors": [
        {
          "host": "https://ghcr.nju.edu.cn",
          "capabilities": ["pull", "resolve"],
          "skip_verify": false
        }
      ]
    },
    {
      "prefix": "nvcr.io",
      "port": 5008,
      "mirrors": [
        {
          "host": "https://ngc.nju.edu.cn",
          "capabilities": ["pull", "resolve"],
          "skip_verify": false
        }
      ]
    }
  ]
}
